generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon requires directUrl for migrations
  directUrl = env("DATABASE_URL")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  url       String
  title     String
  favicon   String?
  folderId  String?
  createdAt DateTime @default(now())

  @@unique([userId, url])
  @@index([userId])
}

model HistoryEntry {
  id        String   @id @default(cuid())
  userId    String
  url       String
  title     String
  favicon   String?
  visitedAt DateTime @default(now())

  @@index([userId, visitedAt(sort: Desc)])
}